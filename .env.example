# Go File Service Configuration
# Copy this file to .env and customize as needed

# Service Port (default: 50051)
# Change this to run multiple instances on different ports
FILE_SERVICE_PORT=50051

# Maximum file size in MB (default: 100)
# Files larger than this will be rejected
MAX_FILE_SIZE_MB=100

# Temporary directory for processing
# Set to a custom path if needed, defaults to system temp dir
TEMP_DIR=/tmp/file-service

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Environment: development, staging, production
ENVIRONMENT=development

# gRPC message size limit in MB (default: 100)
# Maximum message size that can be sent/received
GRPC_MAX_MESSAGE_SIZE_MB=100
